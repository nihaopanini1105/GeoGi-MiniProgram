PORT=3107
HOST=127.0.0.1
PUBLIC_BASE_URL=https://api.example.com
PUBLIC_UPLOAD_BASE_URL=https://api.example.com/uploads
UPLOAD_DIR=./uploads
REPORT_FONT_PATH=
CONTACT_WECHAT_ID=GeoGi-Advisor
CONTACT_WORK_HOURS=工作日 10:00-19:00

# WeChat mini program phone authorization
WECHAT_APP_ID=wx_xxx
WECHAT_APP_SECRET=xxx

# Feishu app
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# Bitable: leads
FEISHU_BASE_APP_TOKEN=appxxx
FEISHU_LEADS_TABLE_ID=tblxxx
FEISHU_RECORD_URL_TEMPLATE=https://xxx.feishu.cn/base/{appToken}?table={tableId}&record={recordId}

# Bitable: diagnosis workbench
FEISHU_PROJECTS_TABLE_ID=tblxxx
FEISHU_BRAND_PROFILE_TABLE_ID=tblxxx
FEISHU_SOURCES_TABLE_ID=tblxxx
FEISHU_KEYWORDS_TABLE_ID=tblxxx
FEISHU_QUESTIONS_TABLE_ID=tblxxx
FEISHU_AI_QUESTION_TABLE_ID=tblxxx
FEISHU_TEST_RECORDS_TABLE_ID=tblxxx
FEISHU_ANALYSIS_TABLE_ID=tblxxx
FEISHU_REPORTS_TABLE_ID=tblxxx

# Bitable: research articles
FEISHU_CONTENT_APP_TOKEN=appxxx
FEISHU_ARTICLES_TABLE_ID=tblxxx

# Notification: use webhook first for MVP
FEISHU_NOTIFY_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
FEISHU_NOTIFY_SECRET=

# Optional app-bot private message
FEISHU_NOTIFY_RECEIVE_ID=
FEISHU_NOTIFY_RECEIVE_ID_TYPE=open_id
