page {
  min-height: 100%;
  background: #F3F7FF;
  color: #081B3A;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
  letter-spacing: 0;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 32rpx 32rpx calc(160rpx + env(safe-area-inset-bottom));
}

.section {
  margin-top: 32rpx;
}

.section-head {
  margin-bottom: 24rpx;
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  min-height: 52rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(47, 109, 255, 0.16);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #2F6DFF;
  font-size: 24rpx;
  font-weight: 500;
}

.h1 {
  display: block;
  margin-top: 16rpx;
  color: #081B3A;
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1.3;
}

.h2 {
  display: block;
  color: #081B3A;
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.35;
}

.lead {
  display: block;
  margin-top: 14rpx;
  color: #66789A;
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1.55;
}

.body {
  color: #66789A;
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1.55;
}

.muted {
  color: #8DA0BD;
}

.card {
  border: 1rpx solid #D9E6FA;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 8rpx 24rpx rgba(40, 85, 170, 0.06);
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #EAF1FF;
  color: #2F6DFF;
  font-size: 22rpx;
  font-weight: 500;
}

.primary-button,
.secondary-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 0 30rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.primary-button {
  background: #2F6DFF;
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(40, 85, 170, 0.12);
}

.primary-button:active {
  background: #245DEB;
}

.secondary-button {
  border: 1rpx solid rgba(47, 109, 255, 0.2);
  background: rgba(255, 255, 255, 0.86);
  color: #081B3A;
}

.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 30rpx;
}

.list {
  display: grid;
  gap: 20rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 13rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #2dc38a, #73d8b3);
  flex: 0 0 auto;
}

.safe-bottom {
  height: calc(160rpx + env(safe-area-inset-bottom));
}
