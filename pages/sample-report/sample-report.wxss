.report-hero,
.score-card,
.dimension-card,
.outline-card {
  padding: 32rpx 30rpx;
}

.score-label,
.score-value,
.dimension-name,
.dimension-score,
.outline-title {
  display: block;
}

.score-card {
  background: linear-gradient(135deg, #0f2d89, #2f6df6);
  color: #ffffff;
}

.score-label {
  color: rgba(255, 255, 255, 0.76);
  font-size: 26rpx;
  font-weight: 850;
}

.score-value {
  margin: 10rpx 0 16rpx;
  font-size: 92rpx;
  font-weight: 950;
  line-height: 1;
}

.score-card .body {
  color: rgba(255, 255, 255, 0.86);
}

.dimension-top {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.dimension-name {
  color: #102145;
  font-size: 32rpx;
  font-weight: 950;
}

.dimension-score {
  color: #2f6df6;
  font-size: 34rpx;
  font-weight: 950;
}

.outline-title {
  margin-bottom: 18rpx;
  color: #102145;
  font-size: 34rpx;
  font-weight: 950;
}

.outline-row {
  display: flex;
  gap: 18rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #ecf1fa;
  color: #51617f;
  font-size: 27rpx;
}

.outline-num {
  color: #2f6df6;
  font-weight: 950;
}

.full-button {
  width: 100%;
  margin-top: 34rpx;
}
