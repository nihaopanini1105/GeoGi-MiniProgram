.success-card,
.next-card,
.contact-card,
.article-card {
  padding: 34rpx 30rpx;
}

.success-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 20rpx;
  border-radius: 999rpx;
  background: #2dc38a;
  color: #ffffff;
  font-size: 54rpx;
  font-weight: 600;
}

.block-title {
  display: block;
  margin-bottom: 22rpx;
  color: #081B3A;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.28;
}

.success-id {
  display: block;
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #f5f8ff;
  color: #2F6DFF;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.35;
}

.muted-id {
  color: #66789A;
}

.next-row,
.article-row {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #ecf1fa;
  color: #51617f;
  font-size: 27rpx;
  line-height: 1.6;
}

.next-num {
  color: #2F6DFF;
  font-weight: 600;
  flex: 0 0 auto;
}

.full-button {
  width: 100%;
  margin-top: 28rpx;
}

.estimate-copy {
  display: block;
  color: #51617f;
  font-size: 28rpx;
  line-height: 1.72;
}

.article-row {
  justify-content: space-between;
  align-items: center;
}

.arrow {
  color: #2F6DFF;
  font-size: 42rpx;
}

.home-button {
  margin-top: 34rpx;
}
