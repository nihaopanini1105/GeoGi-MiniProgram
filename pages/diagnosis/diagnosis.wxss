.intro-hero,
.auth-card,
.step-card,
.form-card,
.detail-card,
.platform-card {
  padding: 30rpx;
}

.auth-card {
  min-height: 760rpx;
  padding: 52rpx 36rpx 42rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f5f8ff 100%);
}

.auth-icon {
  width: 112rpx;
  height: 112rpx;
  margin-bottom: 28rpx;
}

.auth-points {
  display: grid;
  gap: 18rpx;
  margin-top: 34rpx;
}

.auth-point {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 58rpx;
  color: #102145;
  font-size: 27rpx;
  font-weight: 850;
}

.auth-point image {
  width: 34rpx;
  height: 34rpx;
}

.auth-button {
  width: 100%;
  height: 96rpx;
  margin-top: 44rpx;
  border-radius: 30rpx;
  font-size: 30rpx;
}

.intro-hero {
  background: linear-gradient(180deg, #ffffff 0%, #f6f9ff 100%);
}

.intro-hero .h1 {
  margin-top: 0;
  font-size: 58rpx;
}

.intro-button {
  width: 100%;
  height: 96rpx;
  margin-top: 34rpx;
  border-radius: 32rpx;
  font-size: 30rpx;
}

.section-title,
.note-title,
.note-copy,
.form-title,
.field-label,
.field-error,
.submit-error {
  display: block;
}

.section-title {
  color: #102145;
  font-size: 38rpx;
  font-weight: 950;
  line-height: 1.2;
}

.platform-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 24rpx;
}

.platform-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 130rpx;
  color: #102145;
  font-size: 23rpx;
  font-weight: 850;
}

.platform-item image {
  width: 76rpx;
  height: 76rpx;
  margin-bottom: 12rpx;
}

.check-list {
  display: grid;
  gap: 18rpx;
  margin-top: 24rpx;
}

.check-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 54rpx;
  color: #102145;
  font-size: 28rpx;
  font-weight: 820;
}

.check-row image {
  width: 34rpx;
  height: 34rpx;
}

.delivery-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.delivery-card {
  min-height: 138rpx;
  padding: 24rpx;
}

.delivery-card image {
  width: 44rpx;
  height: 44rpx;
}

.delivery-card text {
  display: block;
  margin-top: 14rpx;
  color: #102145;
  font-size: 28rpx;
  font-weight: 900;
}

.note-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 30rpx;
}

.note-title {
  color: #102145;
  font-size: 34rpx;
  font-weight: 950;
}

.note-copy {
  margin-top: 10rpx;
  color: #60708f;
  font-size: 26rpx;
  line-height: 1.55;
}

.note-card .secondary-button {
  min-width: 190rpx;
  flex: 0 0 auto;
}

.step-card {
  position: sticky;
  top: 0;
  z-index: 10;
  background: rgba(255, 255, 255, 0.98);
}

.progress {
  height: 8rpx;
  margin-bottom: 24rpx;
  border-radius: 999rpx;
  background: #edf3fb;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #2f6df6;
}

.step-1 {
  width: 33.33%;
}

.step-2 {
  width: 66.66%;
}

.step-3 {
  width: 100%;
}

.step-header {
  display: flex;
  align-items: center;
}

.step-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  border-radius: 999rpx;
  background: #edf4ff;
  color: #6b7897;
  font-size: 24rpx;
  font-weight: 900;
}

.step-dot.active {
  background: #2f6df6;
  color: #ffffff;
}

.step-line {
  flex: 1;
  height: 4rpx;
  background: #dbe4f2;
}

.step-line.active {
  background: #2f6df6;
}

.step-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 14rpx;
  color: #6b7897;
  font-size: 23rpx;
}

.form-card {
  margin-top: 24rpx;
}

.form-title {
  color: #102145;
  font-size: 36rpx;
  font-weight: 950;
}

.field {
  margin-top: 28rpx;
}

.field-label {
  margin-bottom: 14rpx;
  color: #102145;
  font-size: 28rpx;
  font-weight: 900;
}

input,
textarea,
.select-field {
  width: 100%;
  border: 1rpx solid #dbe4f2;
  border-radius: 24rpx;
  background: #f8fbff;
  color: #0d1b4c;
  font-size: 28rpx;
}

input {
  height: 92rpx;
  padding: 0 24rpx;
}

textarea {
  min-height: 92rpx;
  padding: 25rpx 24rpx;
  line-height: 1.45;
}

.auto-textarea {
  max-height: 260rpx;
}

.select-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 92rpx;
  padding: 0 24rpx;
  color: #0d1b4c;
  font-size: 28rpx;
}

.select-field.empty {
  color: #9aa8c0;
}

.select-arrow {
  width: 16rpx;
  height: 16rpx;
  border-right: 3rpx solid #6b7897;
  border-bottom: 3rpx solid #6b7897;
  transform: rotate(45deg);
  flex: 0 0 auto;
}

.placeholder {
  color: #9aa8c0;
}

.chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.select-chip {
  min-height: 68rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(219, 228, 242, 0.95);
  background: #ffffff;
  color: #51617f;
  font-size: 25rpx;
  font-weight: 850;
  line-height: 1.25;
}

.select-chip.active {
  border-color: rgba(47, 109, 246, 0.28);
  background: rgba(47, 109, 246, 0.1);
  color: #2f6df6;
}

.field-error,
.submit-error {
  margin-top: 12rpx;
  color: #d84b4b;
  font-size: 24rpx;
  line-height: 1.45;
}

.submit-error {
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fff3f3;
}

.upload-button {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  min-height: 88rpx;
  border: 1rpx dashed #b9c8dd;
  border-radius: 24rpx;
  background: #f8fbff;
  color: #2f6df6;
  font-size: 27rpx;
  font-weight: 900;
}

.upload-button image {
  width: 36rpx;
  height: 36rpx;
}

.upload-list {
  margin-top: 16rpx;
}

.upload-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 72rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: #f3f7ff;
  color: #102145;
  font-size: 25rpx;
}

.upload-item text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.upload-item button {
  min-width: 76rpx;
  min-height: 60rpx;
  color: #d84b4b;
  font-size: 24rpx;
  font-weight: 900;
}

.privacy-row {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
  color: #51617f;
  font-size: 26rpx;
  line-height: 1.55;
}

.check {
  width: 36rpx;
  height: 36rpx;
  margin-top: 3rpx;
  border-radius: 10rpx;
  border: 2rpx solid #b8c5d8;
  flex: 0 0 auto;
}

.check.checked {
  border-color: #2f6df6;
  background: #2f6df6;
}

.privacy-link {
  min-height: 64rpx;
  margin-top: 14rpx;
  color: #2f6df6;
  font-size: 25rpx;
  font-weight: 900;
  text-align: left;
}

.phone-locked {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 92rpx;
  padding: 0 24rpx;
  border: 1rpx solid #dbe4f2;
  border-radius: 24rpx;
  background: #f8fbff;
  color: #0d1b4c;
  font-size: 28rpx;
  font-weight: 850;
}

.phone-tag {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(47, 109, 246, 0.1);
  color: #2f6df6;
  font-size: 23rpx;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  display: flex;
  gap: 18rpx;
  padding: 20rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(219, 228, 242, 0.95);
}

.half-button {
  width: 210rpx;
}

.grow-button {
  flex: 1;
}

@media (max-width: 350px) {
  .intro-hero .h1 {
    font-size: 52rpx;
  }

  .platform-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .delivery-grid {
    grid-template-columns: 1fr;
  }

  .note-card {
    display: block;
  }

  .note-card .secondary-button {
    width: 100%;
    margin-top: 22rpx;
  }
}
