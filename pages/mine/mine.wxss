.mine-page {
  padding-bottom: 96rpx;
}

.mine-head,
.client-card,
.order-card,
.empty-card {
  padding: 32rpx 30rpx;
}

.mine-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.mine-head .h1 {
  font-size: 54rpx;
}

.mine-head .lead {
  max-width: 450rpx;
}

.refresh-button {
  flex: 0 0 auto;
  min-width: 120rpx;
  min-height: 64rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(47, 109, 255, 0.1);
  color: #2F6DFF;
  font-size: 24rpx;
  font-weight: 600;
}

.client-card {
  margin-top: 24rpx;
}

.client-label {
  display: block;
  color: #66789A;
  font-size: 24rpx;
  font-weight: 600;
}

.client-id {
  display: block;
  margin-top: 8rpx;
  color: #081B3A;
  font-size: 34rpx;
  font-weight: 600;
}

.error-tip {
  display: block;
  margin: 22rpx 4rpx 0;
  color: #b45b20;
  font-size: 24rpx;
  line-height: 1.6;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.order-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.order-title-wrap {
  min-width: 0;
}

.order-brand {
  display: block;
  color: #081B3A;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.25;
}

.order-meta {
  display: block;
  margin-top: 10rpx;
  color: #66789A;
  font-size: 25rpx;
  line-height: 1.5;
}

.status-pill {
  flex: 0 0 auto;
  max-width: 210rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(107, 120, 151, 0.11);
  color: #66789A;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.25;
  text-align: center;
}

.status-pill.ready {
  background: rgba(47, 109, 255, 0.12);
  color: #2F6DFF;
}

.order-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 24rpx;
  color: #66789A;
  font-size: 24rpx;
  line-height: 1.5;
}

.order-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 26rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #ecf1fa;
  color: #2F6DFF;
  font-size: 27rpx;
  font-weight: 600;
}

.arrow {
  color: #8da0bf;
  font-size: 40rpx;
  line-height: 1;
}

.empty-card {
  margin-top: 34rpx;
  text-align: center;
}

.empty-icon {
  width: 104rpx;
  height: 104rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  display: block;
  color: #081B3A;
  font-size: 36rpx;
  font-weight: 600;
}

.empty-card .body {
  display: block;
  margin-top: 14rpx;
}

.full-button {
  width: 100%;
  margin-top: 30rpx;
}
