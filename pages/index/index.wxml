<view class="page index-page">
  <view class="top-safe"></view>

  <view class="hero">
    <view class="hero-copy">
      <text class="h1 hero-title">看看 AI 会不会
推荐你的品牌</text>
      <text class="lead hero-lead">1分钟查看品牌曝光、竞品表现和优化方向</text>

      <view class="hero-tips">
        <view class="tip">
          <image src="{{assets.icons.checkCircle}}" mode="aspectFit"></image>
          <text>5大AI平台</text>
        </view>
        <view class="tip">
          <image src="{{assets.icons.checkCircle}}" mode="aspectFit"></image>
          <text>品牌对比结果</text>
        </view>
      </view>

      <button class="primary-button hero-button" bindtap="goDiagnosis">
        <text>免费检测</text>
        <image src="{{assets.icons.arrowRight}}" mode="aspectFit"></image>
      </button>
    </view>

    <image class="hero-mark" src="{{assets.hero.mark}}" mode="aspectFit"></image>
  </view>

  <view class="section platform-card card">
    <text class="section-title">覆盖主流 AI 平台</text>
    <view class="platform-grid">
      <view class="platform-item" wx:for="{{platforms}}" wx:key="key">
        <image class="platform-logo" src="{{item.icon}}" mode="aspectFit"></image>
        <text>{{item.name}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head compact">
      <text class="section-title">GeoGi 可以帮你了解</text>
    </view>
    <view class="value-grid">
      <view class="value-card card" wx:for="{{values}}" wx:key="text">
        <image src="{{item.icon}}" mode="aspectFit"></image>
        <text>{{item.text}}</text>
      </view>
    </view>
  </view>

  <view class="section research-section">
    <view class="section-row">
      <text class="section-title">知识库 · 最新洞察</text>
      <button class="text-button inline-link" bindtap="goResearch">查看全部</button>
    </view>
    <view class="article-list card">
      <view class="article-item" wx:for="{{latestArticles}}" wx:key="id" data-id="{{item.id}}" bindtap="openArticle">
        <view class="article-main">
          <text class="pill">{{item.category}}</text>
          <text class="article-title">{{item.title}}</text>
          <text class="article-date">{{item.date}}</text>
        </view>
        <image src="{{assets.icons.arrowRight}}" mode="aspectFit"></image>
      </view>
    </view>
  </view>

  <view class="section flow-card card">
    <view class="section-row">
      <text class="section-title">服务流程</text>
      <button class="text-button inline-link" bindtap="goDiagnosis">了解更多</button>
    </view>
    <view class="flow-list">
      <view class="flow-item" wx:for="{{flow}}" wx:key="*this">
        <text class="flow-num">{{index + 1}}</text>
        <text class="flow-title">{{item}}</text>
      </view>
    </view>
  </view>

  <view class="section contact-card">
    <view>
      <text class="contact-title">需要帮助？联系 GeoGi 顾问</text>
      <text class="contact-copy">不确定怎么填资料，也可以先沟通业务场景。</text>
    </view>
    <button class="secondary-button contact-button" bindtap="goContact">联系顾问</button>
  </view>

  <view class="safe-bottom"></view>
</view>
