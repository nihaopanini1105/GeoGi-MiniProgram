.index-page {
  padding-top: 0;
}

.top-safe {
  height: 28rpx;
}

.hero {
  position: relative;
  min-height: 510rpx;
  padding: 46rpx 34rpx 42rpx;
  border: 1rpx solid rgba(219, 228, 242, 0.95);
  border-radius: 36rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f5f8ff 100%);
  box-shadow: 0 18rpx 46rpx rgba(17, 47, 122, 0.06);
  overflow: hidden;
}

.hero-copy {
  position: relative;
  z-index: 2;
  width: 76%;
}

.hero-title {
  margin-top: 0;
  max-width: 520rpx;
  font-size: 62rpx;
  line-height: 1.12;
}

.hero-lead {
  max-width: 470rpx;
  margin-top: 20rpx;
  font-size: 28rpx;
  line-height: 1.68;
}

.hero-tips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 26rpx;
}

.tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #f3f7ff;
  color: #53627f;
  font-size: 23rpx;
  font-weight: 800;
}

.tip image {
  width: 26rpx;
  height: 26rpx;
}

.hero-button {
  width: 360rpx;
  height: 96rpx;
  margin-top: 32rpx;
  border-radius: 32rpx;
  gap: 12rpx;
  font-size: 30rpx;
}

.hero-button image {
  width: 34rpx;
  height: 34rpx;
}

.hero-mark {
  position: absolute;
  right: 20rpx;
  top: 62rpx;
  width: 238rpx;
  height: 238rpx;
  z-index: 1;
}

.section-title,
.article-title,
.article-date,
.contact-title,
.contact-copy {
  display: block;
}

.section-title {
  color: #102145;
  font-size: 38rpx;
  font-weight: 950;
  line-height: 1.2;
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.text-button {
  min-width: 112rpx;
  min-height: 64rpx;
  color: #2f6df6;
  font-size: 25rpx;
  font-weight: 900;
}

.platform-card {
  padding: 28rpx 22rpx 24rpx;
}

.platform-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 24rpx;
}

.platform-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 132rpx;
  color: #102145;
  font-size: 23rpx;
  font-weight: 850;
  text-align: center;
}

.platform-logo {
  width: 76rpx;
  height: 76rpx;
  margin-bottom: 12rpx;
}

.value-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
}

.value-card {
  min-height: 156rpx;
  padding: 20rpx 14rpx 18rpx;
  text-align: center;
}

.value-card image {
  width: 42rpx;
  height: 42rpx;
}

.value-card text {
  display: block;
  margin-top: 14rpx;
  color: #102145;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 1.32;
}

.article-list {
  margin-top: 20rpx;
  padding: 4rpx 24rpx;
}

.article-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-height: 150rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #ecf1fa;
}

.article-item:last-child {
  border-bottom: 0;
}

.article-main {
  min-width: 0;
}

.article-title {
  margin-top: 10rpx;
  color: #102145;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.34;
}

.article-date {
  margin-top: 10rpx;
  color: #6b7897;
  font-size: 23rpx;
}

.article-item image {
  width: 32rpx;
  height: 32rpx;
  flex: 0 0 auto;
  opacity: 0.62;
}

.flow-card {
  padding: 28rpx 24rpx;
}

.flow-list {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 24rpx;
}

.flow-item {
  min-height: 116rpx;
  padding: 18rpx 10rpx;
  border-radius: 24rpx;
  background: #f8fbff;
  text-align: center;
}

.flow-num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 999rpx;
  background: #2f6df6;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 950;
}

.flow-title {
  display: block;
  margin-top: 12rpx;
  color: #102145;
  font-size: 23rpx;
  font-weight: 850;
  line-height: 1.3;
}

.contact-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  padding: 30rpx 28rpx;
  border-radius: 34rpx;
  background: #102145;
  color: #ffffff;
}

.contact-title {
  font-size: 34rpx;
  font-weight: 950;
  line-height: 1.24;
}

.contact-copy {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 25rpx;
  line-height: 1.5;
}

.contact-button {
  min-width: 176rpx;
  height: 80rpx;
  border-color: rgba(255, 255, 255, 0.22);
  background: #ffffff;
  color: #102145;
  flex: 0 0 auto;
}

@media (max-width: 350px) {
  .hero {
    min-height: 600rpx;
    padding: 44rpx 28rpx 36rpx;
  }

  .hero-copy {
    width: 100%;
  }

  .hero-title {
    max-width: 430rpx;
    font-size: 58rpx;
  }

  .hero-lead {
    max-width: 430rpx;
  }

  .hero-mark {
    top: auto;
    right: 18rpx;
    bottom: 42rpx;
    width: 176rpx;
    height: 176rpx;
  }

  .platform-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .value-grid,
  .flow-list {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .contact-card {
    display: block;
  }

  .contact-button {
    width: 100%;
    margin-top: 24rpx;
  }
}
