.hero {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 820rpx;
  min-height: calc(100vh - 210rpx);
  padding: 34rpx 30rpx 28rpx;
  border: 1rpx solid rgba(219, 228, 242, 0.9);
  border-radius: 36rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7faff 100%);
  box-shadow: 0 18rpx 50rpx rgba(17, 47, 122, 0.06);
  overflow: hidden;
}

.brand-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.brand-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #2f6df6, #204fcb);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 26rpx rgba(47, 109, 246, 0.24);
}

.brand-name,
.brand-sub {
  display: block;
}

.brand-name {
  color: #102145;
  font-size: 31rpx;
  font-weight: 900;
}

.brand-sub {
  margin-top: 6rpx;
  color: #6b7897;
  font-size: 21rpx;
}

.nav-pill {
  flex: 0 0 auto;
  min-height: 58rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #f0f5ff;
  color: #2f6df6;
  font-size: 24rpx;
  font-weight: 900;
}

.hero-main {
  padding: 72rpx 2rpx 54rpx;
}

.hero-title {
  max-width: 590rpx;
  margin-top: 24rpx;
  font-size: 64rpx;
  line-height: 1.1;
  letter-spacing: 0;
}

.hero-lead {
  max-width: 610rpx;
  margin-top: 20rpx;
  font-size: 28rpx;
  line-height: 1.62;
}

.diagnosis-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 44rpx;
  padding: 22rpx 22rpx 22rpx 26rpx;
  border: 1rpx solid rgba(47, 109, 246, 0.16);
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 42rpx rgba(17, 47, 122, 0.07);
}

.entry-title,
.entry-copy {
  display: block;
}

.entry-title {
  color: #102145;
  font-size: 30rpx;
  font-weight: 950;
}

.entry-copy {
  margin-top: 8rpx;
  color: #6b7897;
  font-size: 24rpx;
}

.entry-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: #2f6df6;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 950;
  box-shadow: 0 14rpx 32rpx rgba(47, 109, 246, 0.26);
}

.hero-links {
  display: flex;
  justify-content: center;
  gap: 10rpx;
  margin-top: 26rpx;
}

.hero-links button {
  min-height: 46rpx;
  padding: 0 14rpx;
  color: #53627f;
  font-size: 24rpx;
  font-weight: 800;
}

.hero-proof {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 10rpx;
  border: 1rpx solid rgba(219, 228, 242, 0.95);
  border-radius: 24rpx;
  background: rgba(248, 251, 255, 0.92);
}

.proof-item {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.proof-value,
.proof-label {
  display: block;
}

.proof-value {
  color: #102145;
  font-size: 22rpx;
  font-weight: 950;
  line-height: 1.2;
}

.proof-divider {
  width: 1rpx;
  height: 34rpx;
  background: #dbe4f2;
}

.stats-row {
  display: flex;
  gap: 16rpx;
}

.metric {
  flex: 1;
  padding: 24rpx 14rpx;
  text-align: center;
}

.metric-value,
.metric-label,
.card-title,
.cta-title,
.cta-copy,
.faq-q,
.article-date {
  display: block;
}

.metric-value {
  color: #2f6df6;
  font-size: 38rpx;
  font-weight: 950;
}

.metric-label {
  margin-top: 8rpx;
  color: #6b7897;
  font-size: 22rpx;
}

.service-card {
  padding: 28rpx;
}

.pain-card,
.flow-card,
.report-card,
.faq-card {
  padding: 28rpx;
}

.pain-list {
  display: grid;
  gap: 14rpx;
  margin-top: 22rpx;
}

.pain-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 68rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
  background: #f8fbff;
  color: #51617f;
  font-size: 26rpx;
  font-weight: 850;
  line-height: 1.45;
}

.ability-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.ability-card {
  min-height: 112rpx;
  padding: 26rpx 18rpx;
  color: #102145;
  font-size: 28rpx;
  font-weight: 900;
  text-align: center;
}

.flow-list {
  display: grid;
  gap: 14rpx;
  margin-top: 24rpx;
}

.flow-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #f8fbff;
  border: 1rpx solid #e3ebf7;
}

.flow-num {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: #2f6df6;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
}

.flow-title {
  color: #102145;
  font-size: 28rpx;
  font-weight: 900;
}

.report-button {
  width: 100%;
  margin-top: 24rpx;
}

.article-card {
  padding: 28rpx;
}

.article-date {
  margin-top: 18rpx;
  color: #6b7897;
  font-size: 24rpx;
}

.faq-item {
  padding: 22rpx 0;
  border-top: 1rpx solid #ecf1fa;
}

.faq-q {
  margin-bottom: 8rpx;
  color: #102145;
  font-size: 29rpx;
  font-weight: 950;
}

.card-title {
  margin: 18rpx 0 10rpx;
  color: #102145;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.28;
}

.cta-card {
  padding: 34rpx 30rpx;
  border-radius: 34rpx;
  background: linear-gradient(135deg, #0f2d89, #2f6df6);
  color: #ffffff;
  box-shadow: 0 22rpx 54rpx rgba(23, 59, 175, 0.28);
}

.cta-title {
  font-size: 40rpx;
  font-weight: 950;
  line-height: 1.18;
}

.cta-copy {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 28rpx;
  line-height: 1.75;
}

.cta-button {
  width: 100%;
  margin-top: 28rpx;
  background: #ffffff;
  color: #1236a9;
  box-shadow: none;
}

.text-link {
  width: 100%;
  margin-top: 20rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 27rpx;
  font-weight: 850;
}
