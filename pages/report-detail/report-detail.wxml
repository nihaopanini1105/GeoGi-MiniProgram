<view class="page report-page">
  <view wx:if="{{loading}}" class="state-card card">
    <image class="state-icon" src="/assets/icons/png/96/report.png" mode="aspectFit"></image>
    <text class="state-title">正在读取报告</text>
    <text class="body">正在同步诊断工作台数据。</text>
  </view>

  <view wx:elif="{{error}}" class="state-card card">
    <image class="state-icon" src="/assets/icons/png/96/info.png" mode="aspectFit"></image>
    <text class="state-title">暂时无法查看</text>
    <text class="body">{{error}}</text>
    <button class="primary-button full-button" bindtap="refresh">重新读取</button>
    <button class="secondary-button full-button" bindtap="goMine">返回我的</button>
  </view>

  <block wx:else>
    <view class="report-hero card">
      <text class="eyebrow">GEOGI REPORT</text>
      <text class="h1">{{report.title}}</text>
      <text class="lead">{{report.conclusion}}</text>
      <view class="report-meta">
        <text>项目编号：{{order.projectId}}</text>
        <text>报告状态：{{report.status}}</text>
        <text wx:if="{{report.updatedAt}}">更新时间：{{report.updatedAt}}</text>
      </view>
      <button wx:if="{{report.reportLink}}" class="primary-button full-button pdf-button" bindtap="openPdf">打开PDF报告</button>
    </view>

    <view class="section score-card card">
      <view>
        <text class="score-label">综合可见度</text>
        <text class="score-value">{{report.overallScore || '--'}}</text>
      </view>
      <text class="score-desc">{{report.summary}}</text>
    </view>

    <view class="section card scope-card">
      <text class="block-title">诊断范围</text>
      <view class="scope-row" wx:for="{{report.scope}}" wx:key="*this">
        <text>{{item}}</text>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <text class="h2">核心评分</text>
      </view>
      <view class="dimension-card card" wx:for="{{report.dimensions}}" wx:key="key">
        <view class="dimension-top">
          <text class="dimension-name">{{item.name}}</text>
          <view class="dimension-score-wrap">
            <text class="dimension-level">{{item.level}}</text>
            <text class="dimension-score">{{item.score || '--'}}</text>
          </view>
        </view>
        <view class="score-track">
          <view class="score-fill" style="width: {{item.score}}%;"></view>
        </view>
        <text class="body">{{item.desc}}</text>
      </view>
    </view>

    <view class="section card finding-card">
      <text class="block-title">关键发现</text>
      <view class="finding-row" wx:for="{{report.keyFindings}}" wx:key="*this">
        <text class="dot"></text>
        <text>{{item}}</text>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <text class="h2">平台表现</text>
      </view>
      <view wx:if="{{report.platforms.length}}" class="platform-card card" wx:for="{{report.platforms}}" wx:key="name">
        <view class="platform-top">
          <text class="platform-name">{{item.name}}</text>
          <text class="platform-status">{{item.status}}</text>
        </view>
        <text class="platform-question">{{item.question}}</text>
        <text class="answer-preview">{{item.answerPreview}}</text>
        <view class="tag-row">
          <text>提到品牌：{{item.mentioned}}</text>
          <text>主动推荐：{{item.recommended}}</text>
          <text>信息准确：{{item.accurate}}</text>
        </view>
        <text class="platform-issue">{{item.issue}}</text>
      </view>
      <view wx:if="{{!report.platforms.length}}" class="state-card card compact">
        <text class="state-title">平台问答待完成</text>
        <text class="body">完成五个平台问答并在飞书群触发生成报告后，这里会显示平台表现和证据。</text>
      </view>
    </view>

    <view class="section card advice-card">
      <text class="block-title">优化建议</text>
      <view class="advice-row" wx:for="{{report.recommendations}}" wx:key="*this">
        <text class="advice-num">0{{index + 1}}</text>
        <text>{{item}}</text>
      </view>
    </view>

    <view class="section card contact-card">
      <text class="block-title">需要解读报告？</text>
      <text class="body">诊断顾问可以帮你确认品牌主体、信源缺口和下一步优化优先级。</text>
      <button class="primary-button full-button" bindtap="goContact">联系诊断顾问</button>
    </view>
  </block>
</view>
