.report-page {
  padding-bottom: 96rpx;
}

.state-card,
.report-hero,
.score-card,
.scope-card,
.dimension-card,
.finding-card,
.platform-card,
.advice-card,
.contact-card {
  padding: 32rpx 30rpx;
}

.state-card {
  text-align: center;
}

.state-card.compact {
  text-align: left;
}

.state-icon {
  width: 104rpx;
  height: 104rpx;
  margin-bottom: 22rpx;
}

.state-title,
.block-title,
.dimension-name,
.platform-name {
  display: block;
  color: #102145;
  font-weight: 950;
}

.state-title {
  font-size: 36rpx;
}

.block-title {
  margin-bottom: 20rpx;
  font-size: 34rpx;
}

.report-hero .h1 {
  font-size: 48rpx;
  line-height: 1.18;
}

.report-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #ecf1fa;
  color: #6b7897;
  font-size: 24rpx;
  line-height: 1.5;
}

.pdf-button {
  margin-top: 26rpx;
}

.score-card {
  display: flex;
  gap: 28rpx;
  align-items: center;
  background: linear-gradient(135deg, #0f2d89, #2f6df6);
  color: #ffffff;
}

.score-label {
  display: block;
  color: rgba(255, 255, 255, 0.74);
  font-size: 24rpx;
  font-weight: 850;
  white-space: nowrap;
}

.score-value {
  display: block;
  margin-top: 8rpx;
  font-size: 86rpx;
  font-weight: 950;
  line-height: 1;
}

.score-desc {
  flex: 1;
  color: rgba(255, 255, 255, 0.88);
  font-size: 25rpx;
  line-height: 1.7;
}

.scope-row {
  padding: 16rpx 0;
  border-top: 1rpx solid #ecf1fa;
  color: #51617f;
  font-size: 26rpx;
  line-height: 1.55;
}

.scope-row:first-of-type {
  border-top: 0;
}

.dimension-card {
  margin-bottom: 20rpx;
}

.dimension-top,
.platform-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.dimension-name,
.platform-name {
  font-size: 32rpx;
  line-height: 1.3;
}

.dimension-score-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dimension-level,
.platform-status {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(47, 109, 246, 0.1);
  color: #2f6df6;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 1.2;
}

.dimension-score {
  color: #102145;
  font-size: 34rpx;
  font-weight: 950;
}

.score-track {
  height: 12rpx;
  margin: 22rpx 0 18rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e8eef8;
}

.score-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #2f6df6, #28c7a8);
}

.finding-row,
.advice-row {
  display: flex;
  gap: 18rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #ecf1fa;
  color: #51617f;
  font-size: 27rpx;
  line-height: 1.65;
}

.dot {
  flex: 0 0 auto;
  width: 12rpx;
  height: 12rpx;
  margin-top: 18rpx;
  border-radius: 50%;
  background: #28c7a8;
}

.platform-card {
  margin-bottom: 20rpx;
}

.platform-question {
  display: block;
  margin-top: 22rpx;
  color: #102145;
  font-size: 28rpx;
  font-weight: 850;
  line-height: 1.55;
}

.answer-preview {
  display: block;
  margin-top: 16rpx;
  color: #60708f;
  font-size: 25rpx;
  line-height: 1.7;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.tag-row text {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: #f1f5fb;
  color: #60708f;
  font-size: 22rpx;
  font-weight: 800;
}

.platform-issue {
  display: block;
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #ecf1fa;
  color: #102145;
  font-size: 26rpx;
  font-weight: 850;
  line-height: 1.6;
}

.advice-num {
  flex: 0 0 auto;
  color: #2f6df6;
  font-weight: 950;
}

.full-button {
  width: 100%;
  margin-top: 28rpx;
}

@media (max-width: 360px) {
  .score-card {
    align-items: flex-start;
    flex-direction: column;
  }

  .dimension-top,
  .platform-top {
    flex-direction: column;
  }
}
